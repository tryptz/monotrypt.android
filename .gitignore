keystore.properties
# Exception: the project-local debug keystore is committed so every checkout /
# CI build / local build signs `./gradlew installDebug` with the same key —
# otherwise each machine's generated ~/.android/debug.keystore would force a
# full uninstall on the device before each update.
!app/monotrypt-debug.keystore

